# Flask secret key - change this to a strong, random value
SECRET_KEY='your_super_secret_key_here'

# SQLAlchemy Database URI
# For SQLite, the database file will be stored in the 'instance' folder
SQLALCHEMY_DATABASE_URI='sqlite:///instance/jo4dev.db'

# Port for the Flask application
PORT=6010

# Admin user credentials for initial setup
ADMIN_USERNAME='admin'
ADMIN_PASSWORD='admin123' # IMPORTANT: Change this default password immediately!

# Google Calendar booking integration
# Create a Google Cloud service account, download its JSON key,
# then share your Google Calendar with the service account email.
GOOGLE_CALENDAR_ID='primary'
GOOGLE_SERVICE_ACCOUNT_FILE='instance/google-service-account.json'
